{
  "expo": {
    "name": "Golazo Live",
    "slug": "golazo-live",
    "version": "1.0.6",
    "orientation": "portrait",
    "icon": "./assets/splash.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0F0F"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "buildNumber": "16",
      "bundleIdentifier": "com.golazo.live",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/splash.png",
        "backgroundColor": "#0F0F0F"
      },
      "package": "com.golazo.live",
      "edgeToEdgeEnabled": true,
      "versionCode": 18,
      "permissions": [
        "POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/splash.png"
    },
    "plugins": [
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-4426239227155022~7457705262",
          "iosAppId": "ca-app-pub-4426239227155022~9892296911"
        }
      ],
      "expo-updates"
    ],
    "updates": {
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/59b38426-e039-4780-851b-adf6a92751f6"
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "extra": {
      "eas": {
        "projectId": "5e68a1f5-4732-49d8-8990-1ecdf3d8778d"
      }
    }
  }
}
